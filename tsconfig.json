{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["ES2017"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "declaration": true,
    "outDir": "lib",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["jest"]
  },
  "include": ["src/**/*", "tests/**/*"]
}
